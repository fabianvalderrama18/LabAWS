import boto3
import os

# Configuración
NOMBRE_BUCKET = 's3valderrama18'

def ejecutar_subida(archivo_local):
    s3 = boto3.client('s3')
    nombre_s3 = os.path.basename(archivo_local)
    
    try:
        print(f"Subiendo {nombre_s3}...")
        s3.upload_file(archivo_local, NOMBRE_BUCKET, nombre_s3)
        print("✅ Subida exitosa.")
    except Exception as e:
        print(f"❌ Error: {e}")

if __name__ == "__main__":
    # Cambia 'prueba.txt' por el nombre del archivo que quieras subir
    archivo = 'prueba.txt'
    
    if os.path.exists(archivo):
        ejecutar_subida(archivo)
    else:
        # Esto crea un archivo rápido si no existe para que no falle la prueba
        with open(archivo, 'w') as f:
            f.write("Archivo de prueba para AWS")
        ejecutar_subida(archivo)
